{
  "name": "ebupot-unifikasictas-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright test automation for Ebupot Unifikasi CTAS",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:wpdn": "playwright test tests/wpdn",
    "codegen": "playwright codegen",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.18",
    "dotenv": "^16.4.7",
    "typescript": "^5.8.3"
  }
}

